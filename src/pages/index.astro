---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				padding: 1em 0 2em 0;
			}
			.hero h1 {
				font-size: 2.2em;
				margin-bottom: 0.4em;
			}
			.recent-posts ul {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.recent-posts li {
				margin-bottom: 1.2em;
			}
			.recent-posts a {
				text-decoration: none;
				color: rgb(var(--black));
				font-size: 1.15em;
				font-weight: 700;
			}
			.recent-posts a:hover {
				color: rgb(var(--accent));
			}
			.recent-posts .date {
				display: block;
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
			.all-posts-link {
				display: inline-block;
				margin-top: 1em;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>{SITE_TITLE}</h1>
				<p>
					BTCの自動売買ボットを実際に開発・運用している筆者が、ボットの仕組み・バックテスト・VPSでの
					24時間運用ノウハウ・仮想通貨取引所の使い方を、実体験ベースで解説するブログです。
				</p>
			</section>
			<section class="recent-posts">
				<h2>最新記事</h2>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								<span class="date">
									<FormattedDate date={post.data.pubDate} />
								</span>
							</li>
						))
					}
				</ul>
				<a class="all-posts-link" href="/blog">記事一覧を見る →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>
