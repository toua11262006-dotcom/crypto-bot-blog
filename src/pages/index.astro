---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const posts = allPosts.slice(0, 6);
const totalPosts = allPosts.length;
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			/* ヒーロー */
			.hero {
				position: relative;
				overflow: hidden;
				background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
				border-radius: 16px;
				padding: 3em 2.5em;
				color: #fff;
				margin-bottom: 2.5em;
				box-shadow: var(--box-shadow);
			}
			.hero::after {
				content: '';
				position: absolute;
				top: -40%;
				right: -10%;
				width: 380px;
				height: 380px;
				background: radial-gradient(circle, rgba(255, 255, 255, 0.16), transparent 70%);
				pointer-events: none;
				z-index: 0;
			}
			.hero::before {
				content: '';
				position: absolute;
				inset: 0;
				background-image: radial-gradient(rgba(255, 255, 255, 0.09) 1px, transparent 1px);
				background-size: 22px 22px;
				mask-image: linear-gradient(120deg, #000 20%, transparent 75%);
				-webkit-mask-image: linear-gradient(120deg, #000 20%, transparent 75%);
				pointer-events: none;
				z-index: 0;
			}
			.hero > * {
				position: relative;
				z-index: 1;
			}
			.hero-meta {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.9em;
				margin-top: 1.6em;
				font-size: 0.78em;
				color: rgba(255, 255, 255, 0.85);
			}
			.hero-meta .dot {
				width: 4px;
				height: 4px;
				border-radius: 50%;
				background: rgba(255, 255, 255, 0.45);
			}
			.hero-meta strong {
				color: #fff;
				font-size: 1.15em;
			}
			.hero .badge {
				display: inline-block;
				background: rgba(255, 255, 255, 0.18);
				border: 1px solid rgba(255, 255, 255, 0.35);
				border-radius: 999px;
				padding: 0.2em 1em;
				font-size: 0.75em;
				letter-spacing: 0.05em;
				margin-bottom: 1em;
			}
			.hero h1 {
				color: #fff;
				font-size: 2.4em;
				margin-bottom: 0.4em;
				line-height: 1.25;
			}
			.hero p {
				color: rgba(255, 255, 255, 0.92);
				font-size: 0.95em;
				max-width: 34em;
				margin-bottom: 1.6em;
			}
			.hero-actions {
				display: flex;
				gap: 1em;
				flex-wrap: wrap;
			}
			.btn {
				display: inline-block;
				border-radius: 8px;
				padding: 0.55em 1.4em;
				font-weight: 700;
				text-decoration: none;
				font-size: 0.9em;
				transition: 0.2s ease;
			}
			.btn-primary {
				background: #fff;
				color: var(--accent-dark);
			}
			.btn-primary:hover {
				transform: translateY(-2px);
				color: var(--accent);
			}
			.btn-ghost {
				border: 2px solid rgba(255, 255, 255, 0.7);
				color: #fff;
			}
			.btn-ghost:hover {
				background: rgba(255, 255, 255, 0.15);
				color: #fff;
			}
			.btn-primary-solid {
				background: var(--accent);
				color: #fff;
			}
			.btn-primary-solid:hover {
				background: var(--accent-dark);
				color: #fff;
				transform: translateY(-2px);
			}
			/* 特徴カード */
			.features {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.2em;
				margin-bottom: 3em;
			}
			.feature {
				display: block;
				text-decoration: none;
				color: inherit;
				background: #fff;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 14px;
				padding: 1.5em 1.5em;
				transition: 0.2s ease;
			}
			.feature:hover {
				transform: translateY(-3px);
				box-shadow: 0 8px 22px rgba(var(--gray), 22%);
				border-color: transparent;
			}
			.feature h3 {
				transition: color 0.2s ease;
			}
			.feature:hover h3 {
				color: var(--accent);
			}
			.feature h3::after {
				content: ' →';
				color: var(--accent);
				opacity: 0;
				transition: opacity 0.2s ease;
			}
			.feature:hover h3::after {
				opacity: 1;
			}
			.feature .icon {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 2.5em;
				height: 2.5em;
				border-radius: 12px;
				font-size: 1.3em;
				line-height: 1;
				margin-bottom: 0.8em;
			}
			.feature.f1 .icon {
				background: #e6f1fb;
			}
			.feature.f2 .icon {
				background: #e1f5ee;
			}
			.feature.f3 .icon {
				background: #faece7;
			}
			.feature h3 {
				font-size: 1.05em;
				margin-bottom: 0.4em;
			}
			.feature p {
				font-size: 0.8em;
				color: rgb(var(--gray));
				margin: 0;
			}
			/* セクション見出し共通(アクセントバー) */
			.roadmap h2,
			.section-head h2 {
				position: relative;
				padding-left: 0.55em;
			}
			.roadmap h2::before,
			.section-head h2::before {
				content: '';
				position: absolute;
				left: 0;
				top: 0.12em;
				bottom: 0.12em;
				width: 5px;
				border-radius: 3px;
				background: var(--accent);
			}
			/* はじめての方ロードマップ */
			.roadmap {
				margin-bottom: 3em;
			}
			.roadmap h2 {
				font-size: 1.6em;
				margin-bottom: 0.3em;
			}
			.roadmap .lead {
				color: rgb(var(--gray));
				font-size: 0.9em;
				margin-bottom: 1.2em;
			}
			.roadmap ol {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.roadmap li {
				position: relative;
				padding: 0 0 1.4em 3.4em;
			}
			.roadmap li:not(:last-child)::before {
				content: '';
				position: absolute;
				left: 1.1em;
				top: 2.4em;
				bottom: 0.2em;
				width: 3px;
				background: rgb(var(--gray-light));
				border-radius: 2px;
			}
			.roadmap .step-num {
				position: absolute;
				left: 0;
				top: 0;
				width: 2.2em;
				height: 2.2em;
				border-radius: 50%;
				background: var(--accent);
				color: #fff;
				font-weight: 700;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 1em;
			}
			.roadmap a {
				font-weight: 700;
				font-size: 1.05em;
				text-decoration: none;
				color: rgb(var(--black));
			}
			.roadmap a:hover {
				color: var(--accent);
			}
			.roadmap .step-desc {
				margin: 0.15em 0 0 0;
				font-size: 0.82em;
				color: rgb(var(--gray));
			}
			/* 新着記事 */
			.section-head {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				margin-bottom: 1em;
			}
			.section-head h2 {
				font-size: 1.6em;
				margin: 0;
			}
			.section-head a {
				font-size: 0.85em;
				text-decoration: none;
				font-weight: 700;
			}
			.post-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.5em;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.post-card {
				background: #fff;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				overflow: hidden;
				transition: 0.2s ease;
			}
			.post-card:hover {
				box-shadow: 0 6px 20px rgba(var(--gray), 30%);
				transform: translateY(-3px);
			}
			.post-card a {
				display: block;
				text-decoration: none;
				color: inherit;
				height: 100%;
			}
			.post-card img {
				width: 100%;
				height: auto;
				display: block;
				border-radius: 0;
			}
			.post-body {
				padding: 1em 1.2em 1.2em;
			}
			.post-body .title {
				font-size: 0.95em;
				font-weight: 700;
				color: rgb(var(--black));
				line-height: 1.45;
				margin: 0 0 0.5em 0;
			}
			.post-card:hover .title {
				color: var(--accent);
			}
			.post-body .desc {
				font-size: 0.75em;
				color: rgb(var(--gray));
				margin: 0 0 0.6em 0;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.post-body .card-foot {
				display: flex;
				align-items: center;
				justify-content: space-between;
				margin-top: 0.7em;
			}
			.post-body .date {
				font-size: 0.7em;
				color: rgb(var(--gray));
			}
			.post-body .more {
				font-size: 0.72em;
				font-weight: 700;
				color: var(--accent);
			}
			/* 無料ツール CTA カード */
			.tool-callout {
				display: flex;
				gap: 1.3em;
				align-items: flex-start;
				background:
					linear-gradient(135deg, rgba(35, 55, 255, 0.07), rgba(35, 55, 255, 0.02));
				border: 1px solid rgba(35, 55, 255, 0.22);
				border-radius: 16px;
				padding: 1.7em 1.9em;
				margin-bottom: 3em;
			}
			.tool-callout .tool-icon {
				flex-shrink: 0;
				width: 3em;
				height: 3em;
				border-radius: 12px;
				background: var(--accent);
				color: #fff;
				font-size: 1.4em;
				display: flex;
				align-items: center;
				justify-content: center;
			}
			.tool-callout h2 {
				font-size: 1.35em;
				margin: 0 0 0.3em 0;
			}
			.tool-callout p {
				font-size: 0.85em;
				color: rgb(var(--gray-dark));
				margin: 0 0 1em 0;
			}
			@media (max-width: 900px) {
				.features,
				.post-grid {
					grid-template-columns: repeat(2, 1fr);
				}
			}
			@media (max-width: 600px) {
				.hero {
					padding: 2em 1.4em;
				}
				.hero h1 {
					font-size: 1.7em;
				}
				.features,
				.post-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<span class="badge">BTC自動売買ボット 実運用中</span>
				<h1>作って、検証して、<br />24時間動かす。</h1>
				<p>
					{SITE_TITLE}は、BTC自動売買ボットを実際に開発・運用している筆者による記録です。
					バックテストの数字も、恥ずかしい失敗談も、そのまま公開しています。
				</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="/blog/crypto-bot-basics/">はじめての方はこちら</a>
					<a class="btn btn-ghost" href="/blog/">記事一覧を見る</a>
				</div>
				<div class="hero-meta">
					<span><strong>{totalPosts}</strong> 記事</span>
					<span class="dot"></span>
					<span>実運用中のBTCボット</span>
					<span class="dot"></span>
					<span>コード付き解説</span>
				</div>
			</section>

			<section class="features">
				<a class="feature f1" href="/blog/backtest-pitfalls/">
					<div class="icon">📊</div>
					<h3>実運用の一次情報</h3>
					<p>バックテストと本番運用に基づく数字だけを書きます。「月利◯◯%」の夢は売りません。</p>
				</a>
				<a class="feature f2" href="/blog/ccxt-python-tutorial/">
					<div class="icon">🛠️</div>
					<h3>コード付きで解説</h3>
					<p>Python・ccxt・VPS構築まで、実際に動かしている構成をコード付きで紹介します。</p>
				</a>
				<a class="feature f3" href="/blog/bot-dormant-bug-story/">
					<div class="icon">💥</div>
					<h3>失敗談も全部公開</h3>
					<p>休眠バグ、バックテストの崩壊…。損した経験こそ、次に始める人の資産になります。</p>
				</a>
			</section>

			<section class="roadmap">
				<h2>はじめてボットを作る人はここから</h2>
				<p class="lead">
					「何から始めればいいか分からない」という方向けに、読む順番をステップにしました。上から順に読めば、仕組みの理解から24時間運用まで一通りたどり着けます。
				</p>
				<ol>
					<li>
						<span class="step-num">1</span>
						<a href="/blog/crypto-bot-basics/">自動売買ボットの仕組みを知る</a>
						<p class="step-desc">ボットとは何か、代表的な戦略、始め方の全体像をつかみます</p>
					</li>
					<li>
						<span class="step-num">2</span>
						<a href="/blog/how-to-choose-exchange/">取引所を選んで口座を作る</a>
						<p class="step-desc">API対応・手数料・流動性。ボット運用に向いた取引所の条件を解説</p>
					</li>
					<li>
						<span class="step-num">3</span>
						<a href="/blog/domestic-to-mexc-transfer/">資金を海外取引所へ送金する</a>
						<p class="step-desc">手数料を抑える通貨の選び方と、資産を失わないための鉄則</p>
					</li>
					<li>
						<span class="step-num">4</span>
						<a href="/blog/api-key-security/">APIキーを安全に発行・管理する</a>
						<p class="step-desc">出金権限OFF・IP制限など、資産を守る5つの鉄則</p>
					</li>
					<li>
						<span class="step-num">5</span>
						<a href="/blog/ccxt-python-tutorial/">Pythonでボットを作る</a>
						<p class="step-desc">ccxtで価格取得から注文まで。コード付きの最初の一歩</p>
					</li>
					<li>
						<span class="step-num">6</span>
						<a href="/blog/backtest-pitfalls/">バックテストで検証する</a>
						<p class="step-desc">「バックテストでは勝てるのに本番で勝てない」を防ぐ3つの罠</p>
					</li>
					<li>
						<span class="step-num">7</span>
						<a href="/blog/vps-bot-24h/">VPSで24時間動かす</a>
						<p class="step-desc">実運用中の構成を公開。サービス化と自動再起動まで</p>
					</li>
					<li>
						<span class="step-num">8</span>
						<a href="/blog/discord-notification-bot/">Discord通知で監視する</a>
						<p class="step-desc">「静かな故障」に気づける通知設計。Python実装例つき</p>
					</li>
				</ol>
			</section>

			<section class="tool-callout">
				<div class="tool-icon">🧮</div>
				<div>
					<h2>無料ツール</h2>
					<p>
						1回の取引の損益と税金をその場で概算できる<a
							href="https://crypto-pnl-calc.pages.dev/">仮想通貨 損益・税金計算ツール</a
						>を公開しています。買値・売値・数量とその年の他の所得を入れるだけで、実現損益と日本の雑所得・総合課税にもとづく概算税額が出て、結果をAIが平易に解説します(登録不要・無料)。
					</p>
					<a class="btn btn-primary-solid" href="https://crypto-pnl-calc.pages.dev/"
						>損益・税金計算ツールを開く →</a
					>
				</div>
			</section>

			<section>
				<div class="section-head">
					<h2>新着記事</h2>
					<a href="/blog/">すべて見る →</a>
				</div>
				<ul class="post-grid">
					{
						posts.map((post) => (
							<li class="post-card">
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image width={480} height={240} src={post.data.heroImage} alt="" />
									)}
									<div class="post-body">
										<h3 class="title">{post.data.title}</h3>
										<p class="desc">{post.data.description}</p>
										<div class="card-foot">
											<span class="date">
												<FormattedDate date={post.data.pubDate} />
											</span>
											<span class="more">続きを読む →</span>
										</div>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
